# ─────────────────────────────────────────────
# GTCP Backend — Environment Variables
# Copy to .env and fill in actual values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database (PostgreSQL 15)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gtcp
DB_USER=gtcp_user
DB_PASSWORD=change_me_in_production
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000
DB_CONNECT_TIMEOUT=2000

# JWT
JWT_ACCESS_SECRET=replace_with_64_char_random_string_for_access_token
JWT_REFRESH_SECRET=replace_with_64_char_random_string_for_refresh_token
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
